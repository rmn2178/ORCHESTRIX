OPENAI_API_KEY=your_openai_api_key_here
MONGODB_URI=mongodb://localhost:27017
DB_NAME=orchestrix

# LLM Provider: openai or ollama
LLM_PROVIDER=openai
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Agent URLs (single laptop mode defaults)
DISCOVERY_AGENT_URL=http://localhost:8001
ANALYSIS_AGENT_URL=http://localhost:8002
SUMMARY_AGENT_URL=http://localhost:8003
CITATION_AGENT_URL=http://localhost:8004

# Execution mode: single or multi
EXECUTION_MODE=single
